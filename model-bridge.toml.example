# Model Bridge 配置模板。
#
# 用法：复制本文件为 model-bridge.toml 并按需修改。
#   cp model-bridge.toml.example model-bridge.toml
#
# 若同目录下没有 model-bridge.toml，程序会用内置默认值启动
# （proxy 127.0.0.1:10010 / admin 127.0.0.1:10020，不加密），仍可正常运行。
#
# 内置 providers 已编译进二进制。如需新增/覆盖供应商定义，
# 写到 ~/.mb/providers.json（同名 id 覆盖内置，新 id 追加）。

[proxy]
host = "127.0.0.1"
port = 10010

[admin]
# 默认仅绑定 loopback：admin API 无应用层鉴权，避免直接暴露。
# 仅在受信网络前置（反向代理 + 鉴权）时才放开为 0.0.0.0。
host = "127.0.0.1"
port = 10020

[database]
path = "model-bridge.db"
# 客户端 mb- API key 的静态加密密钥（base64 编码的 32 字节）。
# 生成：openssl rand -base64 32
# 留空则明文存储（仅适用于 admin 仅暴露在 loopback 的场景）。
encryption_key = ""

[bridge]
# 后台自动刷新模型列表间隔（分钟）
refresh_interval_min = 10
# 后台探测上游 /v1/models 的间隔（分钟），与路由刷新解耦。
# 模型目录变化是天/周级，默认 1440（1 天）。探测成功才更新快照；失败保留旧快照。
probe_interval_min = 1440
# 日志保留天数（超过此天数的 usage_records 行会被每天自动清理，0 禁用自动清理）
log_retention_days = 730
